# Игнорируем файлы окружения с секретами
.env
.env.*

# Игнорируем файлы Vercel, которые не должны попадать в Git
.vercel/
.now/
.nowignore

# Игнорируем файлы Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
*.egg

# Локальные базы данных
*.sqlite3
*.db
*.sqlite

# Игнорируем файлы IDE и редакторов
.idea/
.vscode/
.vscode-test/
.idea_modules/
*.swp
*.swo
*.bak
*.tmp

# Игнорируем файлы Node.js
node_modules/
package-lock.json
yarn.lock
npm-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Артефакты сборки
dist/
build/
out/

# Временные файлы операционной системы
.DS_Store
Thumbs.db
*.ini
*.lnk
ntuser.*

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD
.github/workflows/*.log
.circleci/*.log
.travis.yml
.azure-pipelines/

# Логи и PID-файлы
*.log
*.pid

# Личные файлы
*.docx
*.xlsx
*.pdf
*.zip
*.jpg
*.png

# Бинарные файлы и исполняемые скрипты
*.exe
