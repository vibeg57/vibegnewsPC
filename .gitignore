# Игнорируем файлы окружения с секретами
.env
.env.*

# Игнорируем файлы Vercel, которые не должны попадать в Git
.vercel/

# Игнорируем файлы Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
*.egg

# Игнорируем файлы IDE и редакторов
.idea/
.vscode/
# .project
# .settings/
*.swp
*.swo
*.bak
*.tmp

# Игнорируем файлы сборки и зависимости Node.js (если они случайно попали)
node_modules/
package-lock.json
yarn.lock

# Если ты используешь файлы для локальной разработки, которые не нужны на Vercel
# Например, файлы локальных баз данных, конфигурации и т.п.
# *.sqlite
# *.db
