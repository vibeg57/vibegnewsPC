{
  "version": 2,
  "builds": [
    {
      "src": "app.py",  // Твой основной файл
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" } // Можно добавить для больших проектов, но не обязательно
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/app.py"  // Указываем, что все запросы должны идти на app.py
    }
  ]
}
